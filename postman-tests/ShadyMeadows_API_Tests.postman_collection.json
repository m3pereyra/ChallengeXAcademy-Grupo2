              "pm.test(\"Status code es 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"La respuesta tiene bookingid\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.bookingid).to.exist;\r",
              "});\r",
              "\r",
              "pm.test(\"El nombre es correcto\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.firstname).to.eql(\"Juan\");\r",
              "});"
